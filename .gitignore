# Dependencies
node_modules/

# Build outputs
android/build/
android/.gradle/
android/.cxx/
android/app/build/

# Nitrogen — generated files are committed (consumers need them at build time)
# nitrogen/generated/   ← intentionally NOT ignored

# iOS
ios/build/
ios/Pods/
ios/*.xcworkspace

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Lock files — library doesn't commit its own locks
package-lock.json
yarn.lock
bun.lockb

# IDE
.idea/
*.iml
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS
.DS_Store
.DS_Store?
._*
Thumbs.db

# TypeScript
*.tsbuildinfo
lib/

# Temp
*.tmp
*.temp
